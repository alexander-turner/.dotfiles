{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "theme": "light",
  "skipAutoPermissionPrompt": true,
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Review only the diff/lines being changed by this tool call — ignore pre-existing code unless the change directly touches it. Default to \"allow\".\n\nReturn \"deny\" ONLY for:\n- A definite runtime bug introduced by this change (broken syntax, wrong logic that will fail in normal use)\n- A definite security hole introduced by this change (injection from untrusted input, hardcoded secret VALUE in the file, credentials leaked to logs/argv)\n- A clear regression vs the prior code\n\nDo NOT deny for:\n- Style, naming, comments, or \"maintainability\" preferences\n- Overrides of standard commands (rm/ls/ssh/etc.) — assume intentional\n- Patterns that trust env vars set by the agent harness\n- Item/key NAMES (not values) appearing in error messages\n- \"Could be improved\" or \"consider\" suggestions\n- Performance concerns short of a user-visible >1s regression\n\nIf denying, output one sentence naming the specific bug + line numbers. Otherwise output \"allow\".",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "denyRead": [
        "~/.ssh/**",
        "~/.aws/**",
        "~/.gnupg/**",
        "**/.env*"
      ],
      "denyWrite": [
        "~/.bashrc",
        "~/.zshrc",
        "~/.profile",
        "~/.config/fish/**"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.anthropic.com",
        "registry.npmjs.org",
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com"
      ]
    }
  },
  "permissions": {
    "defaultMode": "auto",
    "deny": [
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(python -c *)",
      "Bash(python3 -c *)",
      "Bash(node -e *)",
      "Bash(fish -c *)",
      "Bash(eval *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "WebFetch(domain:pastebin.com)",
      "WebFetch(domain:transfer.sh)",
      "WebFetch(domain:0x0.st)",
      "WebFetch(domain:gist.github.com)"
    ],
    "allow": [
      "WebFetch",
      "WebSearch",

      "Bash(./venv/bin/python *)",
      "Bash(./venv/bin/pytest *)",

      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",

      "Bash(pnpm install)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run lint*)",

      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log*)",
      "Bash(git branch*)",

      "Bash(ollama:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew services:*)",
      "Bash(defaults read:*)",
      "Bash(docker volume:*)",
      "Bash(docker compose up:*)",
      "Bash(docker run:*)",
      "Bash(docker context *)",
      "Bash(orb status *)",
      "Bash(orb start *)",
      "Bash(launchctl getenv:*)",
      "Bash(launchctl bootout:*)",
      "Bash(launchctl bootstrap:*)",
      "Bash(launchctl load:*)",
      "Bash(launchctl list:*)",
      "Bash(log show:*)",
      "Bash(find:*)",
      "Bash(chmod +x:*)",
      "Bash(crontab -l)",
      "Bash(last reboot *)",
      "Bash(sysctl -n kern.boottime)",
      "Bash(pkill -f \"ollama serve\")",

      "Read(//Applications/**)",
      "Read(//Users/server/.ollama/**)",
      "Read(//etc/ollama/**)",
      "Read(//private/tmp/**)"
    ]
  }
}

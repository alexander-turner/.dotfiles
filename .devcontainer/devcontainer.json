{
  "name": "dotfiles-dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:UTC}"
    },
    "cacheFrom": "ghcr.io/alexander-turner/dotfiles-devcontainer:latest"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--pids-limit=512"
  ],
  "mounts": [
    "source=dotfiles-claude-history-${devcontainerId},target=/commandhistory,type=volume",
    "source=dotfiles-claude-config-${devcontainerId},target=/home/vscode/.claude,type=volume"
  ],
  "remoteUser": "vscode",
  "containerEnv": {
    "DOTFILES_DEVCONTAINER": "1"
  },
  "workspaceFolder": "/workspaces/.dotfiles",
  "waitFor": "postCreateCommand",
  "postCreateCommand": "sudo /workspaces/.dotfiles/.devcontainer/init-firewall.bash && bash /workspaces/.dotfiles/setup.bash --link-only",
  "customizations": {
    "vscode": {
      "extensions": [
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "charliermarsh.ruff"
      ]
    }
  }
}

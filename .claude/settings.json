{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(*iptables*)",
      "Bash(*ip6tables*)",
      "Bash(*ipset*)",
      "Bash(ip route *)",
      "Bash(ip rule *)",
      "Bash(ip link *)",
      "Bash(*sudo*)",
      "Bash(*git remote add *)",
      "Bash(*git remote set-url *)",
      "Bash(*capsh*)",
      "Bash(*setcap*)",
      "Bash(*nsenter*)",
      "Bash(*unshare*)",
      "Bash(*ssh *)",
      "Bash(*scp *)",
      "Bash(*npm publish*)",
      "Bash(*pnpm publish*)",
      "Bash(*twine upload*)",
      "Bash(*git push*--force*)",
      "Bash(*git push* -f*)",
      "Bash(*git push*--delete*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-setup.bash"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git push*|gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-check.bash"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.bash"
          }
        ]
      }
    ]
  }
}

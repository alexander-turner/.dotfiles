{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(~/.cache/claude-monitor/**)",
      "Edit(~/.cache/claude-monitor/**)",
      "Write(~/.cache/claude-monitor/**)",
      "Bash(rm *claude-monitor*)",
      "Bash(truncate *claude-monitor*)",
      "Bash(> *claude-monitor*)",
      "Edit(.claude/hooks/monitor.bash)",
      "Write(.claude/hooks/monitor.bash)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-setup.bash"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/monitor.bash"
          }
        ]
      },
      {
        "matcher": "Bash(git push*|gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-check.bash"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/notify.bash"
          }
        ]
      }
    ]
  }
}

# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# Managed by dotfiles — apps/ssh/config, symlinked to ~/.ssh/config.

# Colima writes per-VM Host blocks (lima0, etc.) into this file.
Include ~/.colima/ssh_config

Host *
    # Keychain integration on macOS; IgnoreUnknown keeps Linux ssh quiet.
    IgnoreUnknown UseKeychain
    UseKeychain yes
    AddKeysToAgent yes

    # Surface dead connections within ~3 min instead of hanging on next keystroke.
    ServerAliveInterval 60
    ServerAliveCountMax 3
    TCPKeepAlive yes

    # Connection multiplexing — reuse one TCP connection per host for 10 min.
    # %C hashes user+host+port to dodge the 108-char Unix socket limit.
    ControlMaster auto
    ControlPath ~/.ssh/cm-%C
    ControlPersist 10m

    # Hash hostnames in known_hosts (no enumeration on a compromised host) and
    # quietly accept rotated server keys when the server proves ownership of the old one.
    HashKnownHosts yes
    UpdateHostKeys yes

# Personal mac-mini on the LAN. `ssh server` → server@mac-mini with agent forwarding.
Host server
    HostName mac-mini
    User server
    ForwardAgent yes

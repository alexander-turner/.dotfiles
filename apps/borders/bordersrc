#!/usr/bin/env bash
# JankyBorders config — paints a colored border around the focused window.
# Pairs with Aerospace tiling. Started by Aerospace's after-startup-command
# (see .aerospace.toml). The shebang is informational; `borders` reads the
# file directly.

options=(
    style=round
    width=6.0
    hidpi=on
    active_color=0xffe1e3e4
    inactive_color=0xff494d64
    background_color=0x442e3440
)

borders "${options[@]}"

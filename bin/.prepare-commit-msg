#!/bin/bash
# prepare-commit-msg — generate a commit message via Venice (E2EE) using
# qwen3-coder-480b. Routes through `mods` so the Venice config in
# apps/mods/mods.yml is the single source of truth for endpoint + model.
# VENICE_INFERENCE_KEY is supplied by `envchain ai`.
#
# Skip with SKIP_LLM_GITHOOK=1, or when git invokes the hook for
# -m/-c/--amend/merge/squash (anything that already has a message).
set -uo pipefail

[ -n "${SKIP_LLM_GITHOOK:-}" ] && exit 0

# $2 is the message source per `git help hook prepare-commit-msg`:
#   message — `-m` / `-F` supplied a message
#   template — commit.template populated the file
#   merge / squash — generated by git
#   commit — `--amend` or `-c` reused an existing commit
# Empty $2 ⇒ plain `git commit`, which is the only case we want to fill.
case "${2:-}" in
message | commit | merge | squash | template) exit 0 ;;
esac

for cmd in mods envchain git; do
  command -v "$cmd" >/dev/null 2>&1 || exit 0
done

PROMPT_FILE="${COMMIT_MSG_PROMPT_FILE:-$HOME/.config/prompts/commit-system-prompt.txt}"
[ -r "$PROMPT_FILE" ] || exit 0

diff="$(git diff --cached)"
[ -z "$diff" ] && exit 0

commit_msg=$(
  printf '%s' "$diff" | envchain ai mods \
    --api venice \
    --model qwen3-coder-480b-a35b-instruct-turbo \
    --raw --quiet --no-cache \
    "$(cat "$PROMPT_FILE")" 2>/dev/null
) || exit 0
[ -z "$commit_msg" ] && exit 0

{ printf '%s\n\n' "$commit_msg"; cat "$1"; } >"$1.tmp" && mv "$1.tmp" "$1"

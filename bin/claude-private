#!/bin/bash
# claude-private — claude-code routed through ccr → Venice / llama-3.3-70b
# (Venice = E2EE between client and inference per CLAUDE.md "AI provider
# routing"; llama-3.3-70b = biggest general-purpose Venice model per
# apps/mods/mods.yml). Sets CLAUDE_NO_SANDBOX=1 because devcontainer can't
# reach host loopback :3456 where ccr listens — trading container isolation
# for E2EE routing. CLAUDE_PRIVATE_DRY_RUN=1 prints the resolved command
# without execing (used by tests/test_claude_private.py).

set -euo pipefail

export ANTHROPIC_BASE_URL="${CCR_URL:-http://127.0.0.1:3456}"
export ANTHROPIC_AUTH_TOKEN="${ANTHROPIC_AUTH_TOKEN:-ccr-routed}"
export CLAUDE_NO_SANDBOX=1
model="${CLAUDE_PRIVATE_MODEL:-venice,llama-3.3-70b}"

# Resolve the real claude binary, skipping (a) ourselves and (b) the
# dotfiles bin/claude sandbox shim — calling the shim would re-enter the
# wrapper chain instead of hitting claude-code. We detect the shim by its
# second-line marker using bash builtins so we don't depend on grep being
# on a restricted PATH.
find_real_claude() {
    local self IFS=:
    self="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    local p candidate cand line2
    for p in $PATH; do
        candidate="$p/claude"
        [[ -x "$candidate" && ! -d "$candidate" ]] || continue
        cand="$(readlink -f "$candidate" 2>/dev/null || echo "$candidate")"
        [[ "$cand" == "$self" ]] && continue
        line2=""
        { IFS= read -r _ && IFS= read -r line2; } <"$cand" 2>/dev/null || true
        [[ "$line2" == "# claude wrapper"* ]] && continue
        echo "$candidate"
        return 0
    done
    return 1
}

real_claude="$(find_real_claude)" || {
    echo "claude-private: real claude binary not found in PATH" >&2
    echo "claude-private: run 'pnpm add -g @anthropic-ai/claude-code' (or bash bin/setup_llm.bash)" >&2
    exit 127
}

if [[ -n "${CLAUDE_PRIVATE_DRY_RUN:-}" ]]; then
    printf 'ANTHROPIC_BASE_URL=%s\n' "$ANTHROPIC_BASE_URL"
    printf 'ANTHROPIC_AUTH_TOKEN=%s\n' "$ANTHROPIC_AUTH_TOKEN"
    printf 'CLAUDE_NO_SANDBOX=%s\n' "$CLAUDE_NO_SANDBOX"
    printf 'real_claude=%s\n' "$real_claude"
    printf 'argv=%s --model %s' "$real_claude" "$model"
    for a in "$@"; do printf ' %q' "$a"; done
    printf '\n'
    exit 0
fi

exec "$real_claude" --model "$model" "$@"

#!/bin/bash
# dotfiles — single entry point for the most common chores in this repo.
#
# Usage:
#   dotfiles doctor [--verbose|--quiet]   # health check
#   dotfiles uninstall [--yes]            # remove $HOME symlinks (restores backups)
#   dotfiles link                         # refresh symlinks only (runs setup.sh --link-only)
#   dotfiles lint [--ci] [--fix]          # run all linters
#
# Wraps the underlying scripts in bin/ and setup.sh so users get a single
# entry point with fish-completable subcommands. All extra args are passed
# through verbatim.

set -euo pipefail

# Resolve repo root even when invoked through ~/.local/bin/dotfiles
# (BSD readlink lacks -f, so walk the symlink chain by hand).
SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
    target="$(readlink "$SCRIPT")"
    case "$target" in
    /*) SCRIPT="$target" ;;
    *) SCRIPT="$(cd "$(dirname "$SCRIPT")" && pwd)/$target" ;;
    esac
done
DOTFILES_DIR="$(cd "$(dirname "$SCRIPT")/.." && pwd)"

usage() {
    cat <<EOF
usage: dotfiles <subcommand> [args...]

subcommands:
  doctor     run health check (bin/doctor.sh)
  uninstall  remove \$HOME symlinks, restore backups (bin/uninstall.sh)
  link       refresh symlinks only (setup.sh --link-only)
  lint       run shellcheck/shfmt/stylua/yamllint/ruff/gitleaks (bin/lint.sh)

Extra args are forwarded to the underlying script.
EOF
}

case "${1:-}" in
"" | -h | --help | help)
    usage
    [[ -z "${1:-}" ]] && exit 2 || exit 0
    ;;
doctor)
    shift
    exec bash "$DOTFILES_DIR/bin/doctor.sh" "$@"
    ;;
uninstall)
    shift
    exec bash "$DOTFILES_DIR/bin/uninstall.sh" "$@"
    ;;
link)
    shift
    exec bash "$DOTFILES_DIR/setup.sh" --link-only "$@"
    ;;
lint)
    shift
    exec bash "$DOTFILES_DIR/bin/lint.sh" "$@"
    ;;
*)
    printf "dotfiles: unknown subcommand %q\n\n" "$1" >&2
    usage >&2
    exit 2
    ;;
esac

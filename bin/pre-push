#!/bin/bash
# Pre-push hook: secrets scan on the push range, then full lint.
#
# Git's pre-push protocol feeds us one line per ref being pushed:
#   <local-ref> <local-sha> <remote-ref> <remote-sha>
# We translate each into a git-log range and hand it to gitleaks via
# GITLEAKS_LOG_OPTS so bin/lint.bash only scans the commits this push adds
# (full-history scans run in CI). Falls back to a full scan when stdin
# isn't a git hook — e.g. running `bash bin/lint.bash` directly.
set -euo pipefail

git_root="$(git rev-parse --show-toplevel)"
zero=0000000000000000000000000000000000000000
log_opts=""

# `read` is the right tool to consume git's per-ref protocol; harmless when
# stdin is closed (the loop just doesn't iterate).
while read -r _local_ref local_sha _remote_ref remote_sha; do
    if [ "$local_sha" = "$zero" ]; then
        if [ "${DEVCONTAINER:-}" = "true" ]; then
            # Block remote ref deletion inside the devcontainer at the OS
            # level so deny-list string-construction bypasses can't delete
            # remote branches.
            echo "ERROR: remote ref deletion blocked by pre-push hook" >&2
            exit 1
        fi
        continue # branch deletion — nothing to scan
    fi
    if [ "$remote_sha" = "$zero" ]; then
        # New branch: scan commits unique to it (not reachable from any
        # ref already on origin).
        log_opts="$log_opts $local_sha --not --remotes=origin"
    else
        if [ "${DEVCONTAINER:-}" = "true" ]; then
            # Block non-fast-forward (force) pushes inside the devcontainer.
            # Git doesn't pass --force to the hook, so we detect it by
            # checking ref ancestry.
            if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
                echo "ERROR: non-fast-forward push blocked by pre-push hook (${remote_sha:0:8} is not ancestor of ${local_sha:0:8})" >&2
                exit 1
            fi
        fi
        log_opts="$log_opts $remote_sha..$local_sha"
    fi
done

if [ -n "$log_opts" ]; then
    export GITLEAKS_LOG_OPTS="${log_opts# }"
fi

# Flip lint.bash's check_gitleaks from SKIP-on-missing to FAIL-on-missing. A
# separate var (not overloading GITLEAKS_LOG_OPTS) so a stray export in the
# user's shell can't hard-fail their normal `bash bin/lint.bash` runs.
export GITLEAKS_REQUIRED=1

"$git_root/bin/lint.bash"
